---
import { createClient } from 'microcms-js-sdk';

// .env ファイルに定義した環境変数を読み込み
const client = createClient({
  serviceDomain: import.meta.env.MICROCMS_SERVICE_DOMAIN,
  apiKey: import.meta.env.MICROCMS_API_KEY,
});

const response = await client.get({
  endpoint: 'news',
  queries: { limit: 5, orders: '-publishedAt' }
});

const newsData = response.contents.map((item : any) => {
  const d = new Date(item.publishedAt);
  
  // 「2026.06.13」の形を生成
  const dateStr = d.toLocaleDateString('ja-JP', {
    year: 'numeric', month: '2-digit', day: '2-digit'
  }).replace(/\//g, '.');
  
  // 「15:30」の形を2桁ゼロパディングで確実に生成
  const hours = String(d.getHours()).padStart(2, '0');
  const minutes = String(d.getMinutes()).padStart(2, '0');
  const timeStr = `${hours}:${minutes}`;

  return {
    id: item.id,
    // 日付と時間を半角スペースで美しく結合
    date: `${dateStr} ${timeStr}`,
    title: item.title,
    body: item.body
  };
});
const companyName = "WakaTec.LLC";
const siteTitle = "合同会社WakaTec - 公式ウェブサイト";

//コピーライト年号表示処理
const startYear = 2019;
const currentYear = new Date().getFullYear();
const copyrightYear = startYear === currentYear ? `${startYear}` : `${startYear}-${currentYear}`;

const hasNews = newsData && newsData.length > 0;
const sidebarNewsList = hasNews ? newsData.slice(0, 2) : [];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{siteTitle}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%230b132b%22/><text y=%2275%22 x=%2212%22 font-family=%22sans-serif%22 font-size=%2275%22 font-weight=%22bold%22 fill=%22%23ffffff%22>W</text></svg>">
  </head>
  <body>
    
    <div class="site-container">
      
      <!-- 固定エリア -->
      <aside class="sidebar">
        <div class="top-group">
          <div class="logo-area">
  <img 
    src="/images/logo.webp" 
    alt="WakaTec Logo" 
    class="shodo-logo-img" 
    width="130"   height="40"  loading="eager" 
    decoding="async" 
  />
  <h1>Learn Technology, Refine Craftsmanship</h1>
</div>
          <nav class="nav-menu">
            <button class="active" data-index="0">ホーム</button>
            <button data-index="1">製品</button>
            <button data-index="2">サービス</button>
            <button data-index="3">会社概要</button>
            <button data-index="4">ご連絡</button>
          </nav>
        </div>

        <!-- お知らせエリア -->
        <div class={`latest-news-trigger ${!hasNews ? 'no-click' : ''}`}>
          <span class="news-label">お知らせ</span>
          {hasNews ? (
            <div class="news-preview-container">
              {sidebarNewsList.map((news:any) => (
                <div class="news-preview-row">
                  <span class="news-preview-date">{news.date}</span>
                  <p class="news-preview-title" data-news-id={news.id}>{news.title}</p>
                </div>
              ))}
              <span class="view-all-btn" id="viewAllTrigger">+ 一覧を見る</span>
            </div>
          ) : (
            <p class="news-no-data-text">現在、新しいお知らせはありません。</p>
          )}
        </div>
      </aside>

      <!-- コンテンツエリア -->
      <main class="content-area">
        <div class="inside-wrapper" id="dynamicContent">
          <!-- JavaScriptで挿入 -->
        </div>
      </main>

      <!-- フッター -->
      <footer class="site-footer">
        <p>&copy; {copyrightYear} {companyName} All Rights Reserved.</p>
      </footer>

    </div>

  </body>
</html>

