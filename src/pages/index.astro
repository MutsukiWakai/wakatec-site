              <input type="email" id="c_email" placeholder="メールアドレス" required />
              <textarea id="c_message" placeholder="ご用件・お問い合わせ内容を入力してください" rows="3" required></textarea>
              <button type="submit" class="submit-btn">メーラーを起動して送信 <span>→</span></button>
            </form>

            <div class="contact-direct">
              <div class="direct-box">
                <h4>直接のお問い合わせ</h4>
                <a href="mailto:${contact.email}" class="direct-link">
                  <span class="direct-icon">✉</span> ${contact.email}
                </a>
                <a href="tel:${contact.tel.replace(/-/g, '')}" class="direct-link">
                  <span class="direct-icon">☎</span> ${contact.tel}
                </a>
                <p class="direct-note">※お急ぎの場合は、お電話または上記アドレスへ直接メールを頂けますと対応いたします。</p>
              </div>
            </div>
          </div>
        `;

        const form = contentWrapper.querySelector('#contactForm');
        form?.addEventListener('submit', (e) => {
          e.preventDefault(); // フォーム本来のリロード挙動を完全にブロック

          const name = contentWrapper.querySelector('#c_name').value;
          const company = contentWrapper.querySelector('#c_company').value || "個人";
          const email = contentWrapper.querySelector('#c_email').value;
          const msg = contentWrapper.querySelector('#c_message').value;

          // 件名と本文のエンコード
          const subject = encodeURIComponent(`【WakaTec問い合わせ】${company} ${name}様`);
          const body = encodeURIComponent(
            `合同会社WakaTec お問い合わせ窓口 行\n\n` +
            `以下の内容でお問い合わせを生成しました。内容に間違いがなければこのまま送信してください。\n\n` +
            `----------------------------------------\n` +
            `【お名前】: ${name}\n` +
            `【貴社名】: ${company}\n` +
            `【返信用アドレス】: ${email}\n` +
            `【お問い合わせ内容】:\n${msg}\n` +
            `----------------------------------------`
          );

          // 目に見えないaタグを生成して確実にクリックイベントを発火させる
          const mailtoLink = document.createElement('a');
          mailtoLink.href = `mailto:${contact.email}?subject=${subject}&body=${body}`;
          
          document.body.appendChild(mailtoLink);
          mailtoLink.click();
          document.body.removeChild(mailtoLink);

          // 📢 追記：メーラー起動と同時にフォームの入力内容を綺麗にクリア
          form.reset();
        });
      }
       else {
        // 通常ページのレンダリング
        contentWrapper.innerHTML = `
          <h2>${pages[currentIndex].title}</h2>
          <p>${pages[currentIndex].body}</p>
        `;
      }

      buttons.forEach((btn, i) => {
        if (i === currentIndex) btn.classList.add('active');
        else btn.classList.remove('active');
      });

      if (currentIndex === 0) {
        document.title = siteTitle;
      } else {
        document.title = `${pages[currentIndex].title} - ${siteTitle}`;
      }
    } 
    
    else if (currentMode === "news-list") {
      document.title = `Press Release - ${siteTitle}`;

      if (!newsData || newsData.length === 0) {
        contentWrapper.innerHTML = `
          <h2>お知らせ</h2>
          <p class="no-news-message">プレスリリースはまだ投稿されていません。</p>
        `;
        buttons.forEach(btn => btn.classList.remove('active'));
        return;
      }

      let listHTML = `<ul class="news-list">`;
      newsData.forEach((news) => {
        listHTML += `
          <li class="news-item" data-id="${news.id}">
            <span class="news-item-date">${news.date}</span>
            <span class="news-item-title">${news.title}</span>
          </li>
        `;
      });
      listHTML += `</ul>`;

      contentWrapper.innerHTML = `
        <h2>お知らせ</h2>
        ${listHTML}
      `;
      buttons.forEach(btn => btn.classList.remove('active'));

      document.querySelectorAll('.news-item').forEach(item => {
        item.addEventListener('click', () => {
          const id = item.getAttribute('data-id');
          engageGear(currentIndex, "news-detail", id); 
        });
      });
    } 
    
    else if (currentMode === "news-detail") {
      const news = newsData.find(n => n.id === selectedNewsId);
      if (news) {
        contentWrapper.innerHTML = `
          <button class="back-to-list" id="backBtn">← 一覧に戻る</button>
          <div class="news-detail-header">
            <span class="news-item-date" style="display: block; margin-bottom: 0.5rem;">${news.date}</span>
            <h2>${news.title}</h2>
          </div>
          <p>${news.body}</p>
        `;
        document.title = `${news.title} - ${siteTitle}`;
        
        document.getElementById('backBtn')?.addEventListener('click', () => {
          engageGear(currentIndex, "news-list");
        });
      }
    }
  }

  // マウスホイール検知
  window.addEventListener('wheel', (event) => {
    if (window.innerWidth <= 768) return;
    if (isTransitioning) return;

    if (currentMode === "news-list") {
      scrollStorage += event.deltaY;
      if (Math.abs(scrollStorage) > 100) {
        engageGear(currentIndex, "page"); 
      }
      return;
    }

    if (currentMode === "news-detail") {
      scrollStorage += event.deltaY;
      const progress = Math.min(Math.abs(scrollStorage) / GEAR_ENGAGE, 1);
      if (contentWrapper) contentWrapper.style.opacity = (1 - (progress * 0.8)).toString();

      const currentNewsIndex = newsData.findIndex(n => n.id === selectedNewsId);

      if (scrollStorage > GEAR_ENGAGE) {
        if (currentNewsIndex < newsData.length - 1) {
          const nextNewsId = newsData[currentNewsIndex + 1].id;
          engageGear(currentIndex, "news-detail", nextNewsId);
        } else {
          scrollStorage = GEAR_ENGAGE;
          if (contentWrapper) contentWrapper.style.opacity = "0.2";
        }
      } 
      else if (scrollStorage < -GEAR_ENGAGE) {
        if (currentNewsIndex > 0) {
          const prevNewsId = newsData[currentNewsIndex - 1].id;
          engageGear(currentIndex, "news-detail", prevNewsId);
        } else {
          scrollStorage = -GEAR_ENGAGE;
          if (contentWrapper) contentWrapper.style.opacity = "0.2";
        }
      }
      return;
    }

    scrollStorage += event.deltaY;
    const progress = Math.min(Math.abs(scrollStorage) / GEAR_ENGAGE, 1);
    if (contentWrapper) contentWrapper.style.opacity = (1 - (progress * 0.8)).toString();

    if (scrollStorage > GEAR_ENGAGE) {
      if (currentIndex < pages.length - 1) engageGear(currentIndex + 1, "page");
      else { scrollStorage = GEAR_ENGAGE; if (contentWrapper) contentWrapper.style.opacity = "0.2"; }
    } 
    else if (scrollStorage < -GEAR_ENGAGE) {
      if (currentIndex > 0) engageGear(currentIndex - 1, "page");
      else { scrollStorage = -GEAR_ENGAGE; if (contentWrapper) contentWrapper.style.opacity = "0.2"; }
    }
  }, { passive: true });

  function engageGear(nextIndex, mode, newsId = null) {
    isTransitioning = true;
    if (contentWrapper) contentWrapper.style.opacity = "0";

    const delay = window.innerWidth <= 768 ? 0 : 100;

    setTimeout(() => {
      currentIndex = nextIndex;
      currentMode = mode;
      selectedNewsId = newsId; 
      render(); 
      scrollStorage = 0;

      if (contentWrapper) contentWrapper.style.opacity = "1";
      
      if (window.innerWidth <= 768) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }

      setTimeout(() => { isTransitioning = false; }, 300);
    }, delay);
  }

  let neutralTimeout;
  window.addEventListener('wheel', () => {
    if (window.innerWidth <= 768) return;
    clearTimeout(neutralTimeout);
    neutralTimeout = setTimeout(() => {
      if (!isTransitioning && (currentMode === "page" || currentMode === "news-detail")) {
        scrollStorage = 0;
        if (contentWrapper) {
          contentWrapper.style.transition = "opacity 0.2s ease";
          contentWrapper.style.opacity = "1";
          setTimeout(() => { contentWrapper.style.transition = "none"; }, 200);
        }
      }
    }, 150);
  });

  // 📢 追記：キーボード（↑ / ↓ / Space）によるページ切り替え制御
  window.addEventListener('keydown', (event) => {
    // スマホ環境、または入力フォームにフォーカスしている間はキー操作を完全に無視（文字入力を阻害しないための絶対防衛ライン）
    if (window.innerWidth <= 768) return;
    if (document.activeElement?.tagName === 'INPUT' || document.activeElement?.tagName === 'TEXTAREA') return;

    // 押されたキーの判定
    const isDownKey = event.key === 'ArrowDown' || event.key === ' ';
    const isUpKey = event.key === 'ArrowUp';

    if (!isDownKey && !isUpKey) return; // 矢印上下とSpace以外はスルー

    // Spaceキーによるデフォルトのページスクロール挙動を強制ブロック
    event.preventDefault();

    if (isTransitioning) return;

    // 1. ニュース一覧モードの時
    if (currentMode === "news-list") {
      if (isUpKey) engageGear(currentIndex, "page");
      return;
    }

    // 2. ニュース詳細モードの時
    if (currentMode === "news-detail") {
      const currentNewsIndex = newsData.findIndex(n => n.id === selectedNewsId);
      if (isDownKey) {
        if (currentNewsIndex < newsData.length - 1) {
          engageGear(currentIndex, "news-detail", newsData[currentNewsIndex + 1].id);
        }
      } else if (isUpKey) {
        if (currentNewsIndex > 0) {
          engageGear(currentIndex, "news-detail", newsData[currentNewsIndex - 1].id);
        }
      }
      return;
    }

    // 3. 通常ページモードの時
    if (isDownKey) {
      if (currentIndex < pages.length - 1) engageGear(currentIndex + 1, "page");
    } else if (isUpKey) {
      if (currentIndex > 0) engageGear(currentIndex - 1, "page");
    }
  });

  // 📢 追記：スマホ環境専用・左右スワイプによるページ切り替え制御
  let touchStartX = 0;
  let touchStartY = 0;

  window.addEventListener('touchstart', (event) => {
    // フォーム入力中はスワイプ誤動作を防ぐため完全スルー
    if (document.activeElement?.tagName === 'INPUT' || document.activeElement?.tagName === 'TEXTAREA') return;
    
    touchStartX = event.changedTouches[0].screenX;
    touchStartY = event.changedTouches[0].screenY;
  }, { passive: true });

  window.addEventListener('touchend', (event) => {
    if (document.activeElement?.tagName === 'INPUT' || document.activeElement?.tagName === 'TEXTAREA') return;
    if (isTransitioning) return;

    const touchEndX = event.changedTouches[0].screenX;
    const touchEndY = event.changedTouches[0].screenY;

    const deltaX = touchEndX - touchStartX;
    const deltaY = touchEndY - touchStartY;

    // 誤動作防止：縦スワイプの動きが大きい場合や、横の移動量が小さい（誤タップ）場合は無視
    if (Math.abs(deltaY) > Math.abs(deltaX)) return; 
    if (Math.abs(deltaX) < 50) return; // 50px以上のスワイプで発動

    // 📢 左に払う（画面が左に流れる＝進む）か、右に払う（画面が右に流れる＝戻る）かの判定
    // ※若井さんの感覚（PC版の矢印下＝次のページ、矢印上＝前のページ）に完全同期
    const isNextSwipe = deltaX < 0; // 左へスワイプ（Next）
    const isPrevSwipe = deltaX > 0; // 右へスワイプ（Prev）

    // 1. ニュース一覧モードの時
    if (currentMode === "news-list") {
      if (isPrevSwipe) engageGear(currentIndex, "page");
      return;
    }

    // 2. ニュース詳細モードの時
    if (currentMode === "news-detail") {
      const currentNewsIndex = newsData.findIndex(n => n.id === selectedNewsId);
      if (isNextSwipe) {
        if (currentNewsIndex < newsData.length - 1) {
          engageGear(currentIndex, "news-detail", newsData[currentNewsIndex + 1].id);
        }
      } else if (isPrevSwipe) {
        if (currentNewsIndex > 0) {
          engageGear(currentIndex, "news-detail", newsData[currentNewsIndex - 1].id);
        }
      }
      return;
    }

    // 3. 通常ページモードの時
    if (isNextSwipe) {
      if (currentIndex < pages.length - 1) engageGear(currentIndex + 1, "page");
    } else if (isPrevSwipe) {
      if (currentIndex > 0) engageGear(currentIndex - 1, "page");
    }
  });

  buttons.forEach((button) => {
    button.addEventListener('click', () => {
      const index = parseInt(button.getAttribute('data-index') || "0");
      engageGear(index, "page");
    });
  });

  document.querySelectorAll('[data-news-id]').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const id = trigger.getAttribute('data-news-id');
      if (id) engageGear(currentIndex, "news-detail", id);
    });
  });

  viewAllTrigger?.addEventListener('click', () => {
    engageGear(currentIndex, "news-list");
  });

  render();
</script>

